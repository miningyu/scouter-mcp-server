{
  "name": "scouter-mcp-server",
  "version": "1.0.1",
  "description": "MCP server for Scouter APM - enables AI agents to query and analyze application performance data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "scouter-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "shx": "^0.3.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/miningyu/scouter-mcp-server.git"
  },
  "homepage": "https://github.com/miningyu/scouter-mcp-server#readme",
  "keywords": [
    "mcp",
    "scouter",
    "apm",
    "monitoring"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
